
{
  "entities": {
    "WorkerProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WorkerProfile",
      "type": "object",
      "description": "Represents an informal worker's profile, containing personal and professional details, linked to an external authentication system.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "name": { "type": "string" },
        "tradeSkill": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "trustScore": { "type": "number" },
        "knowledgePoints": { "type": "number", "description": "Earned through Academy courses." },
        "profileViews": { "type": "number" },
        "isAvailable": { "type": "boolean" },
        "isPro": { "type": "boolean" },
        "whatsappNumber": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "serviceAreas": { "type": "array", "items": { "type": "string" } },
        "referralCode": { "type": "string" },
        "invitedBy": { "type": "string" },
        "referralCount": { "type": "number" },
        "completedCourses": { "type": "array", "items": { "type": "string" }, "description": "IDs of completed Academy videos." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "name", "tradeSkill", "trustScore", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/workerProfiles/{workerId}",
        "definition": {
          "entityName": "WorkerProfile"
        }
      }
    ]
  }
}
