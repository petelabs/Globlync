
{
  "entities": {
    "WorkerProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WorkerProfile",
      "type": "object",
      "description": "Represents an informal worker's profile, containing personal and professional details, linked to an external authentication system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the WorkerProfile entity."
        },
        "username": {
          "type": "string",
          "description": "Unique username for the worker."
        },
        "externalAuthId": {
          "type": "string",
          "description": "Reference to the unique identifier from the external authentication system."
        },
        "name": {
          "type": "string",
          "description": "The full name of the informal worker."
        },
        "tradeSkill": {
          "type": "string",
          "description": "The primary trade or skill of the worker."
        },
        "bio": {
          "type": "string",
          "description": "Professional biography."
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL to the worker's profile picture.",
          "format": "uri"
        },
        "trustScore": {
          "type": "number",
          "description": "A real-time calculated score reflecting reputation."
        },
        "createdAt": {
          "type": "string",
          "description": "Creation timestamp.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Last update timestamp.",
          "format": "date-time"
        },
        "badgeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "username",
        "name",
        "tradeSkill",
        "trustScore",
        "createdAt",
        "updatedAt"
      ]
    },
    "Username": {
      "type": "object",
      "properties": {
        "uid": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "email_link",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/workerProfiles/{workerId}",
        "definition": {
          "entityName": "WorkerProfile",
          "schema": { "$ref": "#/backend/entities/WorkerProfile" },
          "description": "Worker profiles."
        }
      },
      {
        "path": "/usernames/{username}",
        "definition": {
          "entityName": "Username",
          "schema": { "$ref": "#/backend/entities/Username" },
          "description": "Registry of unique usernames mapped to UIDs."
        }
      }
    ]
  }
}
