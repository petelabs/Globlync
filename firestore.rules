
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /system/{document} {
      allow read: if true;
      allow write: if false; 
    }

    // Fixed Posts Rules for Social Feed
    match /posts/{postId} {
      // Allow any signed-in user to see and list posts
      allow read, list: if isSignedIn();
      
      // Post creation restricted to signed-in users
      allow create: if isSignedIn();
      
      // Updates allowed for the author OR for anyone incrementing counts (likes/comments)
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.authorId || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount'])
      );
      
      // Only the author can delete their post
      allow delete: if isSignedIn() && request.auth.uid == resource.data.authorId;
    }

    match /workerProfiles/{workerId} {
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(workerId);
      allow delete: if isOwner(workerId);
      
      allow update: if isOwner(workerId)
                   || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileViews', 'trustScore', 'knowledgePoints', 'completedCourses', 'updatedAt', 'isPro', 'activeBenefits', 'rewardCredits', 'referralCount', 'lastBioPolishAt']));
      
      match /jobs/{jobId} {
        allow read: if true;
        allow create: if isOwner(workerId);
        allow update: if isOwner(workerId) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isVerified', 'updatedAt']);
        allow delete: if isOwner(workerId);
      }
      
      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if true; 
        allow update, delete: if isOwner(workerId);
      }
      
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(workerId);
        allow create: if true; 
      }
    }

    match /chats/{chatId} {
      allow read, list: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if true; 
      allow delete: if isSignedIn();
    }

    match /referralCodes/{code} {
      allow get: if true;
      allow create: if true; 
      allow delete: if isSignedIn();
    }

    match /appRatings/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn();
    }
  }
}
