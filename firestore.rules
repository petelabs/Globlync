
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Global System Settings (Daily Tips, etc.)
    match /system/{document} {
      allow read: if true;
      allow write: if true; 
    }

    // Worker Profiles
    match /workerProfiles/{workerId} {
      // Publicly readable for discovery and profile visits
      allow get, list: if true;
      
      // Only the owner can create their profile
      allow create: if isOwner(workerId);
      
      // Update rules:
      // 1. Owner can update most things
      // 2. Public can update reputation fields (incrementing views, trustScore via verification)
      allow update: if (isOwner(workerId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPro']))
                   || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileViews', 'trustScore', 'referralCount', 'badgeIds', 'updatedAt', 'lastBioPolishAt', 'isPro']));
      
      // Subcollections
      match /jobs/{jobId} {
        allow read: if true;
        allow create: if isOwner(workerId);
        allow update: if isOwner(workerId) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isVerified', 'updatedAt']);
      }
      
      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if true; 
        allow update, delete: if isOwner(workerId);
      }
      
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(workerId);
        allow create: if true; 
      }
    }

    // Registries
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /referralCodes/{code} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    // App Global Feedback
    match /appRatings/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn();
    }
  }
}
