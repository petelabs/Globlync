
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /workerProfiles/{workerId} {
      allow get, list: if true;
      allow create: if isOwner(workerId);
      allow update: if isOwner(workerId) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referralCount', 'badgeIds', 'activeBenefits']));
      
      match /jobs/{jobId} {
        allow get: if true;
        allow list: if isOwner(workerId);
        allow create, update: if isOwner(workerId);
        allow update: if true; 
      }
      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if isOwner(workerId);
      }
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(workerId);
      }
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /referralCodes/{code} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /appRatings/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn();
    }
  }
}
