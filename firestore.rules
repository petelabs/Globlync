
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /system/{document} {
      allow read: if true;
      allow write: if false; 
    }

    match /workerProfiles/{workerId} {
      // Allow public listing and viewing for discovery
      allow get, list: if true; 
      allow create: if isOwner(workerId);
      allow delete: if isOwner(workerId);
      
      allow update: if isOwner(workerId)
                   || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileViews', 'trustScore', 'knowledgePoints', 'completedCourses', 'updatedAt', 'isPro', 'activeBenefits', 'rewardCredits', 'referralCount', 'lastBioPolishAt']));
      
      match /jobs/{jobId} {
        allow get, list: if true; // Explicitly allow public discovery of evidence
        allow create: if isOwner(workerId);
        allow update: if isOwner(workerId) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isVerified', 'updatedAt']);
        allow delete: if isOwner(workerId);
      }
      
      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if true; 
        allow update, delete: if isOwner(workerId);
      }
      
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(workerId);
        allow create: if true; 
      }
    }

    match /communityJobs/{jobId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(request.resource.data.postedBy);
    }

    match /chats/{chatId} {
      allow read, list: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants).participants;
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants).participants;
      }
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if true; 
      allow delete: if isSignedIn();
    }

    match /referralCodes/{code} {
      allow get: if true;
      allow create: if true; 
      allow delete: if isSignedIn();
    }

    match /appRatings/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn();
    }
  }
}
