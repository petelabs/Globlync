
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Global System Settings (Daily Tips, etc.)
    match /system/{document} {
      allow get: if true;
      allow write: if true; // Allow the first daily visitor to trigger AI tip generation
    }

    match /workerProfiles/{workerId} {
      allow get, list: if true;
      allow create: if isOwner(workerId);
      
      // Allow owner to update profile (except isPro)
      // Allow others/system to update reputation fields (referralCount, badgeIds, trustScore, updatedAt, profileViews)
      allow update: if (isOwner(workerId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPro']))
                   || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referralCount', 'badgeIds', 'trustScore', 'updatedAt', 'lastBioPolishAt', 'profileViews']));
      
      match /jobs/{jobId} {
        allow get, list: if true;
        allow create: if isOwner(workerId);
        // Allow owner to edit job OR client to verify job via unique link
        allow update: if isOwner(workerId) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isVerified', 'updatedAt']);
      }
      
      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if true; // Anyone can leave a rating for a job
        allow update, delete: if isOwner(workerId);
      }
      
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(workerId);
        allow create: if true; // Allow system/others to send alerts to the worker
      }
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /referralCodes/{code} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /appRatings/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn();
    }
  }
}
