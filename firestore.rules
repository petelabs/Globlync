
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Global System Settings - Publicly readable for Tips and System Info
    match /system/{document} {
      allow read: if true;
      allow write: if false; 
    }

    // Worker Profiles
    match /workerProfiles/{workerId} {
      allow get: if true; // Publicly viewable for reputation
      allow list: if false; // Browsing all profiles is forbidden for privacy
      allow create: if isOwner(workerId);
      
      // Allow the owner to update everything, or others to increment views/score
      allow update: if isOwner(workerId)
                   || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileViews', 'trustScore', 'updatedAt']));
      
      match /jobs/{jobId} {
        allow read: if true;
        allow create: if isOwner(workerId);
        allow update: if isOwner(workerId) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isVerified', 'updatedAt']);
      }
      
      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if true; 
        allow update, delete: if isOwner(workerId);
      }
      
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(workerId);
        allow create: if true; 
      }
    }

    // Messaging System
    match /chats/{chatId} {
      // Allow listing/reading if the user is a participant
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        // Access messages if the user is a participant in the parent chat
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    // Registries
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /referralCodes/{code} {
      allow get: if true;
      allow create: if isSignedIn();
    }

    match /appRatings/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn();
    }
  }
}
