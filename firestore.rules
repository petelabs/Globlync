
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Publicly accessible system settings
    match /system/{document} {
      allow read: if true;
      allow write: if false; 
    }

    // Worker Profiles: Publicly readable for the directory
    match /workerProfiles/{workerId} {
      allow get, list: if true; 
      allow create: if isOwner(workerId);
      allow delete: if isOwner(workerId);
      
      // Allow updates to public stats from verification triggers or profile owner
      allow update: if isOwner(workerId)
                   || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileViews', 'trustScore', 'knowledgePoints', 'completedCourses', 'updatedAt', 'isPro', 'activeBenefits', 'rewardCredits', 'referralCount', 'lastBioPolishAt', 'onboardingCompleted', 'badgeIds']));
      
      // Verified Job Logs: Publicly readable evidence
      match /jobs/{jobId} {
        allow read, list: if true; 
        allow create: if isOwner(workerId);
        allow update: if isOwner(workerId) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isVerified', 'updatedAt']);
        allow delete: if isOwner(workerId);
      }
      
      // Ratings: Anyone can leave a rating, everyone can see them
      match /ratings/{ratingId} {
        allow read, list: if true;
        allow create: if true; 
        allow update, delete: if isOwner(workerId);
      }
      
      // Notifications: Private to the owner
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(workerId);
        allow create: if true; // Allow system/app to send notifs
      }
    }

    // Community Job Board: Publicly readable, created by signed-in users
    match /communityJobs/{jobId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.postedBy == request.auth.uid);
    }

    // Messaging: Restricted to participants but allows checking existence
    match /chats/{chatId} {
      allow get: if isSignedIn() && (chatId.contains(request.auth.uid));
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    // Username Registry (Public check)
    match /usernames/{username} {
      allow get: if true;
      allow create: if true; 
      allow delete: if isSignedIn();
    }

    // Referral Registry (Public check)
    match /referralCodes/{code} {
      allow get: if true;
      allow create: if true; 
      allow delete: if isSignedIn();
    }
  }
}
